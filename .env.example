# Google Maps JavaScript API key (required for /listings map)
# Get a key: https://developers.google.com/maps/documentation/javascript/get-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google reCAPTCHA v2 (optional, for contact form spam protection)
# Get keys: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Database (PostgreSQL - required for listings & agents)
# Copy to .env.local and add your Neon connection strings.
#
# Neon setup:
#   1. Go to https://neon.tech and create a project (or use existing).
#   2. Dashboard → Connect → enable "Connection pooling".
#   3. Copy the pooled connection string (hostname has -pooler) → DATABASE_URL.
#   4. Copy the direct connection string (no -pooler) → DIRECT_URL.
#   5. Run: npm run db:migrate && npm run db:seed && npm run db:seed-listings
#
# Pooled (for app queries – hostname ends in -pooler):
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Direct (for migrations – no -pooler in hostname).
# For local Postgres, set DIRECT_URL same as DATABASE_URL.
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Admin (required for /admin)
ADMIN_USERNAME=BestCorp
ADMIN_PASSWORD=Rolex123!

# NextAuth (required for admin session)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_secret_here

# Stripe (for lease application fees - Apple Pay, Google Pay, cards)
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret for payment confirmation: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...
# Application fee in cents (default 5000 = $50)
APPLICATION_FEE_CENTS=5000
